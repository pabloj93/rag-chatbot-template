# =============================================================
# rag-chatbot-template — environment variables
# Copy this file to .env and fill in real values. Never commit .env.
# =============================================================

# --- Anthropic (Claude) ---
# Get yours at https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-REPLACE_ME

# In dev we use Haiku (cheap, fast). Switch to Sonnet for demo/eval.
# claude-haiku-4-5-20251001   <- dev default
# claude-sonnet-4-6           <- demo / final eval
CLAUDE_MODEL=claude-haiku-4-5-20251001

# --- Pinecone ---
# Get yours at https://app.pinecone.io/
PINECONE_API_KEY=REPLACE_ME
PINECONE_ENVIRONMENT=us-east-1
PINECONE_INDEX_NAME=anthropic-docs

# --- LangFuse ---
# Get yours at https://cloud.langfuse.com/ (Project Settings -> API Keys)
LANGFUSE_PUBLIC_KEY=pk-lf-REPLACE_ME
LANGFUSE_SECRET_KEY=sk-lf-REPLACE_ME
LANGFUSE_HOST=https://cloud.langfuse.com

# --- App config ---
APP_ENV=development
LOG_LEVEL=INFO
TOP_K=5
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
EMBEDDING_DIM=384

# --- Frontend ---
# In Docker Compose this becomes http://backend:8000
VITE_BACKEND_URL=http://localhost:8000
